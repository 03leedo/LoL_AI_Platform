COMPOSE_PROJECT_NAME=lol_ai_platform

POSTGRES_DB=lol_ai_platform
POSTGRES_USER=lol
POSTGRES_PASSWORD=lol_dev_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://lol:lol_dev_password@postgres:5432/lol_ai_platform

BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000

RIOT_API_KEY=
RIOT_PLATFORM_ROUTING=kr
RIOT_REGIONAL_ROUTING=asia
# App-wide Riot rate budget (dev key: 20/1s, 100/120s). Defaults keep headroom.
RIOT_RATE_LIMIT_PER_SECOND=18
RIOT_RATE_LIMIT_PER_TWO_MINUTES=95
RIOT_REQUEST_MAX_ATTEMPTS=4
RIOT_RETRY_BACKOFF_SECONDS=0.8

LLM_FEEDBACK_ENABLED=false
# The "openai" provider works with any OpenAI-compatible endpoint.
# Google Gemini (free tier) example:
#   OPENAI_API_KEY=<Google AI Studio key>
#   OPENAI_MODEL=gemini-2.5-flash
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# AI report provider: openai | anthropic (no key -> rule-based report fallback)
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
